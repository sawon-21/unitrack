rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && userId != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'Admin') ||
          (request.auth.token.email == "info.vaijan@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.get('userId', null));
      allow update: if 
        (resource != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'viewedBy'])) ||
        (isAuthenticated() && resource != null && (
          (isOwner(resource.data.get('userId', null)) && request.resource.data.get('userId', null) == resource.data.get('userId', null)) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes', 'reposts', 'views', 'commentCount', 'likedBy', 'dislikedBy', 'repostedBy', 'viewedBy', 'lastRepostedAt'])) ||
          isAdmin()
        ));
      allow delete: if resource != null && (isOwner(resource.data.get('userId', null)) || isAdmin());
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.get('userId', null));
      allow update: if isAuthenticated() && resource != null && (
        (isOwner(resource.data.get('userId', null)) && request.resource.data.get('userId', null) == resource.data.get('userId', null)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes', 'likedBy', 'dislikedBy'])) ||
        isAdmin()
      );
      allow delete: if resource != null && (
        isOwner(resource.data.get('userId', null)) || 
        (exists(/databases/$(database)/documents/posts/$(resource.data.get('postId', ''))) && 
         isOwner(get(/databases/$(database)/documents/posts/$(resource.data.get('postId', ''))).data.get('userId', null))) || 
        isAdmin()
      );
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.get('userId', null));
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.get('userId', null)) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.get('userId', null));
    }
  }
}
